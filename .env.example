# ===================== LANDING (.env namunasi) =====================
# Nusxalang: cp .env.example .env — barcha port/manzillar shu fayldan olinadi.

# Landing'ning o'z porti (pnpm dev / pnpm start shu portda ko'tariladi)
PORT=3001

# Saytning kanonik manzili — SEO (canonical, OG, sitemap, robots, JSON-LD) shu qiymatdan oladi.
# Deploy'da haqiqiy domen yozing: https://faceid.uz
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Backend API bazaviy manzili. Faqat domen yozish kifoya — /api/v1 avtomatik qo'shiladi.
# Masalan: https://api.faceid.uz  yoki  http://localhost:3000
# To'liq yozilsa ham ishlaydi: http://localhost:3000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000

# Yagona client SPA (login/register/panel) manzili — vite dev: 5173
# (eski nom NEXT_PUBLIC_COMPANY_PANEL_URL ham qo'llab-quvvatlanadi)
NEXT_PUBLIC_CLIENT_URL=http://localhost:5173
